{
  "name": "wakuwaku-companion",
  "private": true,
  "scripts": {
    "lint": "node scripts/run_lint.mjs",
    "lint:fix": "node scripts/run_lint.mjs --fix",
    "build:frontend": "node scripts/build_frontend.mjs",
    "test:deploy": "python -m unittest tests.test_serve tests.test_deploy -v",
    "test:convex-phase0": "node scripts/verify_convex_phase0.mjs",
    "test:convex-phase1": "node scripts/verify_convex_phase1.mjs",
    "test:convex-phase2": "node scripts/verify_convex_phase2.mjs",
    "test:convex-phase3": "node scripts/verify_convex_phase3.mjs",
    "test:convex-phase4": "node scripts/verify_convex_phase4.mjs",
    "test:convex-phase5": "node scripts/verify_convex_phase5.mjs",
    "test:convex-phase6": "node scripts/verify_convex_phase6.mjs",
    "phase:gate": "node scripts/phase_gate.mjs",
    "design:gate": "node scripts/phase_gate.mjs",
    "test:message-limits": "node scripts/verify_message_limits.mjs && python -m unittest tests.test_message_limits -q",
    "test:voice-ui": "node scripts/verify_voice_ui.mjs",
    "test:voices-dropdown": "node scripts/verify_voices_dropdown.mjs",
    "download:piper-voices": "python scripts/download_piper_voices.py",
    "cleanup:piper-voices": "python scripts/cleanup_piper_voices.py",
    "test:a11y": "playwright test",
    "test:a11y:report": "playwright show-report",
    "kill-ports": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill_dev_ports.ps1",
    "dev": "npm run kill-ports && convex dev --start \"python scripts/run_dev_flask.py\"",
    "dev:flask": "python scripts/run_dev_flask.py",
    "convex:dev": "convex dev",
    "convex:dev:once": "convex dev --once",
    "convex:codegen": "convex codegen",
    "convex:deploy": "convex deploy",
    "convex:set-jwt-keys": "node scripts/set_convex_jwt_keys.mjs",
    "convex:set-jwt-keys:prod": "node scripts/set_convex_jwt_keys.mjs --prod",
    "convex:sync-prod": "node scripts/sync_convex_production.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.51.1",
    "esbuild": "^0.27.0",
    "jose": "^6.2.3"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "convex": "^1.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
